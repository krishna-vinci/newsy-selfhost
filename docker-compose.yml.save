services:
  fastapi:
    build: .
    network_mode: host
    ports:
      - "8666:8666"
    environment:
      - DATABASE_URL=postgresql://krishna:1122@127.0.0.1:5432/youtube_app
      - PIXABAY_API_KEY=your_pixabay_api_key
      - RSSBRIDGE_HOST=https://rssbridge.krishna.quest
      - METUBE_URL=https://metube.krishna.quest
      - NITTER_URL=https://nitter.space
      - PROJECTS_ROOT=/app/data/youtube-videos
      - DAILY_REPORT_DIR=/app/data/daily_report
    volumes:
      - /mnt/youtube-cm/youtube-data:/app/data
      - .:/app
    restart: unless-stopped
