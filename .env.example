# DB Settings (no change needed unless you want to modify)
DB_USER=postgres
DB_PASSWORD=1122
DB_NAME=newsy
DB_HOST=newsy_db
DB_PORT=5432
DATABASE_URL=postgresql://postgres:1122@newsy_db:5432/newsy

# Host port mapping for Postgres
POSTGRES_HOST_PORT=5432

# FastAPI Settings
FASTAPI_HOST_PORT=8321


# Redis Host
REDIS_HOST=redis


# Enable notifications

NTFY_BASE_URL=http://localhost:port # ntfy hosted instance url for feed notification (notification automatically enabled, you just need to copy the topic name from the app)

# Other Services
# RSSBRIDGE_HOST=http://localhost:port #self hosted if avaialable for youtube and custom feeds
# NITTER_URL=https://xcancel.com # nitter public instances

# OpenAI-Compatible API Configuration for AI Content Filtering
# Supports OpenAI, Z.AI, OpenRouter, and other OpenAI-compatible APIs
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1  # Default to OpenAI
OPENAI_MODEL=gpt-4o-mini  # Model to use for filtering
OPENAI_MAX_TOKENS=100  # Max tokens for response
OPENAI_TEMPERATURE=0.3  # Temperature for response (0.0-2.0)

# Example configurations for different providers:
# OpenAI (default):
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_MODEL=gpt-4o-mini
# Google ai opeinai compatible:
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   OPENAI_MODEL=gemini-2.5-flash-lite
# Z.AI:
#   OPENAI_BASE_URL=https://api.z.ai/api/paas/v4/
#   OPENAI_MODEL=glm-4-flash
# OpenRouter:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=anthropic/claude-3.5-sonnet
# Local LLM (e.g., LM Studio, Ollama):
#   OPENAI_API_KEY=not-needed
#   OPENAI_BASE_URL=http://localhost:1234/v1
#   OPENAI_MODEL=llama-3.1-8b

