# DB Settings (no change needed unless you want to modify)
DB_USER=postgres
DB_PASSWORD=1122
DB_NAME=newsy
DB_HOST=newsy_db
DB_PORT=5432
DATABASE_URL=postgresql://postgres:1122@newsy_db:5432/newsy

# Host port mapping for Postgres
POSTGRES_HOST_PORT=5432

# FastAPI Settings
FASTAPI_HOST_PORT=8765



# Redis Host
REDIS_HOST=newsy-redis


# Notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here # telegram bot token for telegram notifications
WEB_PUSH_VAPID_PUBLIC_KEY=your-vapid-public-key-here
WEB_PUSH_VAPID_PRIVATE_KEY=your-vapid-private-key-here
WEB_PUSH_SUBJECT=mailto:you@example.com


# OpenAI-Compatible API Configuration for AI Content Filtering
# Supports OpenAI, Z.AI, OpenRouter, and other OpenAI-compatible APIs
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1  # Default to OpenAI
OPENAI_MODEL=gpt-4o-mini  # Model to use for filtering
OPENAI_MAX_TOKENS=100  # Max tokens for response
OPENAI_TEMPERATURE=0.3  # Temperature for response (0.0-2.0)

# Example configurations for different providers:
# OpenAI (default):
#   OPENAI_BASE_URL=https://api.openai.com/v1
#   OPENAI_MODEL=gpt-4o-mini
# Google ai opeinai compatible:
#   OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   OPENAI_MODEL=gemini-2.5-flash-lite
# Z.AI:
#   OPENAI_BASE_URL=https://api.z.ai/api/paas/v4/
#   OPENAI_MODEL=glm-4-flash
# OpenRouter:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_MODEL=anthropic/claude-3.5-sonnet
# Local LLM (e.g., LM Studio, Ollama):
#   OPENAI_API_KEY=not-needed
#   OPENAI_BASE_URL=http://localhost:1234/v1
#   OPENAI_MODEL=llama-3.1-8b

# CORS Settings (Add your whitelisted origins like ip and domains here)
CORS_ORIGINS=https://your-domain.example,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3456,http://127.0.0.1:3456

# Frontend dev server hosts allowed by Vite in docker-compose.dev.yml
# Use * to allow any host during development if needed.
#DEV_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.example
DEV_ALLOWED_HOSTS=*
# Auth Settings
AUTH_SECRET_KEY=replace-with-a-long-random-secret
AUTH_ACCESS_TTL_MINUTES=15
AUTH_REFRESH_TTL_DAYS=30
AUTH_ALLOW_PUBLIC_SIGNUP=true
# Production should typically keep this true when served over HTTPS.
# docker-compose.dev.yml overrides this to false for easier localhost/IP development.
AUTH_COOKIE_SECURE=true
INTERNAL_API_KEY=replace-with-a-long-random-internal-api-key

# Public app URL used for externally visible links and notifications
PUBLIC_URL=https://your-domain.example

# Cache Settings
CACHE_ENABLED=true  # Enable/disable caching (default: true)
CACHE_DURATION_SECONDS=300  # Cache duration in seconds (default: 300 = 5 minutes)
